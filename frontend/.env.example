# ================================================
# SPOTIFY CLONE - FRONTEND ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env and fill in your values
# Note: Vite uses VITE_ prefix for client-side variables
# ================================================

# ================================================
# API CONFIGURATION
# ================================================
# Backend API Base URL
# Should match the running backend server
VITE_API_URL=http://localhost:5001/api/v1

# ================================================
# APP CONFIGURATION
# ================================================
# Application name
VITE_APP_NAME=Spotify Clone

# Application version
VITE_APP_VERSION=1.0.0

# ================================================
# FEATURES (Optional)
# ================================================
# Enable debug mode
VITE_DEBUG=false

# Audio player autoplay on song selection
VITE_AUTOPLAY=true
