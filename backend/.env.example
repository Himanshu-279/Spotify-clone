# ================================================
# SPOTIFY CLONE - BACKEND ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env file to git
# ================================================

# ================================================
# DATABASE CONFIGURATION
# ================================================
# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_URI=mongodb+srv://username:password@cluster0.sbfo6.mongodb.net/spotify-clone

# ================================================
# SERVER CONFIGURATION
# ================================================
# Port on which the Express server will run
PORT=5001

# ================================================
# JWT AUTHENTICATION
# ================================================
# Secret key for JWT token signing
# Use a strong, random string (min 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-minimum-32-characters-recommended

# ================================================
# FILE UPLOAD CONFIGURATION
# ================================================
# Maximum file size for audio uploads (in bytes)
# Default: 100MB (100 * 1024 * 1024)
MAX_FILE_SIZE=104857600

# Upload directory (relative to backend folder)
UPLOAD_DIR=uploads

# ================================================
# CORS CONFIGURATION
# ================================================
# Frontend URL (for CORS allowed origins)
FRONTEND_URL=http://localhost:3001
